{
  "manifest_version": 3,
  "name": "PolyFly WASM Proof",
  "version": "0.2.0",
  "description": "Mach module via WASM byte-patching. Same menu shape as 0.5.0; applies on next track load.",
  "content_scripts": [
    {
      "matches": ["https://app-polytrack.kodub.com/0.6.1/*"],
      "js": ["src/urlBridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": ["https://app-polytrack.kodub.com/0.6.1/*"],
      "js": ["dist/main.bundle.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/bin/polytrack_mod.wasm"],
      "matches": ["https://app-polytrack.kodub.com/*"]
    }
  ]
}